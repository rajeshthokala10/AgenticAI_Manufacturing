# Copy this to .env and fill in your API key
# Without an API key, the app runs in mock mode with simulated LLM responses
OPENAI_API_KEY=your-api-key-here
LLM_MODEL=gpt-4o-mini
# Default embedder is bge-small-en-v1.5 — same 384-dim as MiniLM but
# stronger on industrial / technical retrieval. Swap freely with any
# sentence-transformers checkpoint.
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Ollama (local models) — install: https://ollama.com, then: ollama pull qwen2.5:3b
OLLAMA_BASE_URL=http://localhost:11434/v1

# Tiered model routing — override per task (defaults shown)
# Strong models for user-facing answers
ANSWER_MODEL=gpt-4o
RETRY_MODEL=gpt-4o
PROCEDURE_MODEL=gpt-4o
# Local Qwen 3B for cheap auxiliary tasks (runs free via Ollama)
CRITIC_MODEL=qwen2.5:3b
CLASSIFY_MODEL=qwen2.5:3b
# Comparison pipelines
DIRECT_LLM_MODEL=gpt-4o-mini
CLASSICAL_RAG_MODEL=gpt-4o-mini

# ── Orchestration ──────────────────────────────────────────────────────────
# Set to true to route diagnostic queries through the LangGraph StateGraph
# (pipeline/langgraph_orchestrator.py) instead of the legacy procedural
# orchestrator. Required for streaming and HITL.
USE_LANGGRAPH=false

# ── Cause-ranking LLM stage (optional) ─────────────────────────────────────
# When true, a dedicated cause-ranking model scores root-cause candidates
# *between* retrieval and answer generation.
USE_CAUSE_RANKING=false
CAUSE_RANK_MODEL=qwen2.5:3b
CAUSE_RANK_TOP_K=5
# Optional fixed cause taxonomy (piston-style). Comma-separated list of
# canonical cause names; the cause-ranker drops any cause NOT in this list
# (anti-hallucination guarantee). Leave empty for free-form output.
# Example: CAUSE_TAXONOMY=BearingWear,SealLeak,BeltSlip,CarbIce,FouledPlug
CAUSE_TAXONOMY=

# ── Two-stage generation (procedure drafting) ─────────────────────────────
# When true, the diagnostic path emits a structured procedure
# { steps: [{step, action, citations}] } via a dedicated LLM call after
# cause-ranking. The Markdown rendering of that procedure replaces the
# free-form answer for troubleshooting intents.
USE_PROCEDURE_DRAFTING=false

# ── Human-in-the-Loop (HITL) approval gate (optional) ──────────────────────
# When true, the LangGraph orchestrator scores each query for risk and pauses
# at a `human_approval` interrupt for anything above HITL_RISK_THRESHOLD.
# Approve/reject from Streamlit's "📋 Approvals" tab or via:
#   POST /api/approvals/{thread_id}/resume  {"approved": true|false, ...}
USE_HITL=false
HITL_RISK_THRESHOLD=0.6
HITL_AUTO_APPROVE_BELOW_USD=2000
HITL_HIGH_RISK_KEYWORDS=lockout,tagout,hot work,fire,explosion,h2s,arc flash,confined space,fatal,injury,death,toxic,asphyxiation,radiation,permit-to-work,shutdown,emergency
HITL_DB_PATH=data/processed/audit.sqlite
HITL_CHECKPOINT_BACKEND=sqlite

# ── Cross-encoder reranker ─────────────────────────────────────────────────
# bge-reranker-base is on by default now (5–15% quality lift on noisy
# industrial corpora). Set USE_RERANKER=false to disable for cold-start
# deployments without the model weights cached.
USE_RERANKER=true
RERANKER_MODEL=BAAI/bge-reranker-base
RERANK_CANDIDATE_POOL=20
RERANK_BLEND_WEIGHT=0.7

# ── Async parallel retrieval ──────────────────────────────────────────────
USE_PARALLEL_RETRIEVAL=true
PARALLEL_RETRIEVAL_TIMEOUT_S=15.0

# ── Semantic cache ────────────────────────────────────────────────────────
USE_SEMANTIC_CACHE=false
SEMANTIC_CACHE_THRESHOLD=0.97
SEMANTIC_CACHE_MAX_SIZE=256
SEMANTIC_CACHE_TTL_SECONDS=3600

# ── Guardrails post-processor ─────────────────────────────────────────────
USE_GUARDRAILS=true
GUARDRAILS_REQUIRE_CITATIONS=true
GUARDRAILS_MIN_CITATIONS=1
GUARDRAILS_BLOCK_UNSAFE=true

# ── Tool-calling agent (ERP / MES / SAP / Database) ───────────────────────
USE_TOOLS=false
TOOL_PLANNER_MODEL=qwen2.5:3b
TOOL_PLANNER_USE_LLM=true

# ── Qdrant vector store ────────────────────────────────────────────────────
# Empty → embedded on-disk at doc_pipeline/vector_store/qdrant/. For remote
# Qdrant, set QDRANT_URL=http://host:6333 (or QDRANT_URL=:memory: for tests).
QDRANT_URL=
QDRANT_COLLECTION=manufacturing_corpus
