# Copy this to .env and fill in your API key
# Without an API key, the app runs in mock mode with simulated LLM responses
OPENAI_API_KEY=your-api-key-here
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Ollama (local models) — install: https://ollama.com, then: ollama pull qwen2.5:3b
OLLAMA_BASE_URL=http://localhost:11434/v1

# Tiered model routing — override per task (defaults shown)
# Strong models for user-facing answers
ANSWER_MODEL=gpt-4o
RETRY_MODEL=gpt-4o
# Local Qwen 3B for cheap auxiliary tasks (runs free via Ollama)
CRITIC_MODEL=qwen2.5:3b
CLASSIFY_MODEL=qwen2.5:3b
# Comparison pipelines
DIRECT_LLM_MODEL=gpt-4o-mini
CLASSICAL_RAG_MODEL=gpt-4o-mini

# ── Orchestration ──────────────────────────────────────────────────────────
# Set to true to route diagnostic queries through the LangGraph StateGraph
# (pipeline/langgraph_orchestrator.py) instead of the legacy procedural
# orchestrator. Both produce the same response shape; LangGraph makes the
# state transitions explicit and is friendlier to LangSmith tracing.
USE_LANGGRAPH=false

# ── Cause-ranking LLM stage (optional) ─────────────────────────────────────
# When true, a dedicated cause-ranking model scores root-cause candidates
# *between* retrieval and answer generation. The ranking is fed into the
# answer LLM's prompt so the final "Root Cause candidates" section is
# anchored on explicit, evidence-cited scores rather than implicit ranking.
# Intent-gated: only fires for troubleshooting / failure-analysis queries.
USE_CAUSE_RANKING=false
CAUSE_RANK_MODEL=qwen2.5:3b
CAUSE_RANK_TOP_K=5
